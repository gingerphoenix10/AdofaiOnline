<?xml version="1.0" encoding="utf-8"?>
<Project Sdk="Microsoft.NET.Sdk">
	
  <PropertyGroup Condition="'$(Configuration)' != 'BepInEx'"> <!-- UMM PropertyGroup -->
    <Platform Condition=" '$(Platform)' == '' ">AnyCPU</Platform>
    <ProjectGuid>{E1F2A3A1-5307-4D6E-AFC0-F62FE6536CB4}</ProjectGuid>
    <OutputType>Library</OutputType>
    <AppDesignerFolder>Properties</AppDesignerFolder>
    <RootNamespace>AdofaiOnline</RootNamespace>
    <AssemblyName>AdofaiOnline</AssemblyName>
	<TargetFramework>net48</TargetFramework>
    <TargetFrameworkVersion>v4.8</TargetFrameworkVersion>
	<LangVersion>13.0</LangVersion>
    <FileAlignment>512</FileAlignment>
    <Deterministic>true</Deterministic>
    <DebugSymbols>true</DebugSymbols>
    <DebugType>full</DebugType>
    <Optimize>false</Optimize>
    <DefineConstants>DEBUG;TRACE;LAN_BUTTONS</DefineConstants>
    <ErrorReport>prompt</ErrorReport>
    <WarningLevel>4</WarningLevel>
  </PropertyGroup>

  <PropertyGroup Condition="'$(Configuration)' == 'BepInEx'"> <!-- BepInEx PropertyGroup -->
      <DefineConstants>BEPIN;DEBUG;LAN_BUTTONS</DefineConstants>
	  <TargetFramework>netstandard2.1</TargetFramework>
	  <AssemblyName>AdofaiOnline</AssemblyName>
	  <Product>AdofaiOnline</Product>
	  <Version>1.0.0</Version>
	  <AllowUnsafeBlocks>true</AllowUnsafeBlocks>
	  <LangVersion>latest</LangVersion>
	  <RestoreAdditionalProjectSources>
		  https://api.nuget.org/v3/index.json;
		  https://nuget.bepinex.dev/v3/index.json;
		  https://nuget.samboy.dev/v3/index.json
	  </RestoreAdditionalProjectSources>
	  <RootNamespace>AdofaiOnline</RootNamespace>
  </PropertyGroup>

  <PropertyGroup> <!-- Combined PropertyGroup -->
	  <ADDir Condition=" '$(ADDir)' == '' ">C:\Program Files (x86)\Steam\steamapps\common\A Dance of Fire and Ice</ADDir>
	  <Configurations>UMM;BepInEx</Configurations>
	  <GenerateAssemblyInfo>false</GenerateAssemblyInfo>
  </PropertyGroup>

  <ItemGroup> <!-- Combined Assemblies -->
    <PackageReference Include="Krafs.Publicizer" Version="2.3.0" />
	<Reference Include="$(ADDir)\A Dance of Fire and Ice_Data\Managed\Assembly-CSharp.dll" Private="False" />
	<Reference Include="$(ADDir)\A Dance of Fire and Ice_Data\Managed\RDTools.dll" Private="False" />
	<Reference Include="$(ADDir)\A Dance of Fire and Ice_Data\Managed\UnityEngine*.dll" Private="False" />
	<Reference Include="$(ADDir)\A Dance of Fire and Ice_Data\Managed\com.rlabrecque.steamworks.net.dll" />
	<Reference Include="$(ADDir)\A Dance of Fire and Ice_Data\Managed\DOTween.dll" />
	<Reference Include="$(ADDir)\A Dance of Fire and Ice_Data\Managed\Unity.TextMeshPro.dll" />
	<Reference Include="$(ADDir)\A Dance of Fire and Ice_Data\Managed\UnityEngine.UI.dll" />
    <Publicize Include="Assembly-CSharp" />
  </ItemGroup>

  <ItemGroup Condition="'$(Configuration)' == 'BepInEx'"> <!-- BepInEx-specific Assemblies -->
    <PackageReference Include="BepInEx.Analyzers" Version="1.*" PrivateAssets="all" />
    <PackageReference Include="BepInEx.Core" Version="5.*" />
    <PackageReference Include="BepInEx.PluginInfoProps" Version="2.*" />
  </ItemGroup>

  <ItemGroup Condition="'$(Configuration)' != 'BepInEx'"> <!-- UMM-specific Assemblies -->
    <Reference Include="System" />
    <Reference Include="System.Core" />
    <Reference Include="System.Xml.Linq" />
    <Reference Include="System.Data.DataSetExtensions" />
    <Reference Include="Microsoft.CSharp" />
    <Reference Include="System.Data" />
    <Reference Include="System.Net.Http" />
    <Reference Include="System.Xml" />
    <Reference Include="$(ADDir)\A Dance of Fire and Ice_Data\Managed\UnityModManager\*.dll" />
  </ItemGroup>

	<Target Name="CopyOutputFileToGame" AfterTargets="Build" Condition="'$(Configuration)' == 'BepInEx'">
		<Copy SourceFiles="$(OutputPath)\$(AssemblyName).dll;$(OutputPath)\$(AssemblyName).pdb" DestinationFolder="$(ADDir)\BepInEx\Plugins\$(MSBuildProjectName)"/>
	</Target>
</Project>